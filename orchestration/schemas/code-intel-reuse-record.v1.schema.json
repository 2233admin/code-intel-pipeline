{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "code-intel-reuse-record.v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "id", "projectId", "subject", "subjectKind", "source", "sourceRevision", "license", "adoptionRung", "ownedBoundary", "necessityEvidence", "compatibilityEvidence", "conformanceEvidence", "economics", "assurance", "ownedModifications", "update", "rollback", "exit", "retirement", "lifecycle", "researchAllowed", "productionEnabled", "diagnostics", "provenance", "engineeringFacts"],
  "properties": {
    "schema": { "const": "code-intel-reuse-record.v1" },
    "id": { "$ref": "#/$defs/id" },
    "projectId": { "$ref": "#/$defs/id" },
    "subject": { "$ref": "#/$defs/id" },
    "subjectKind": { "enum": ["design_reference", "evidence_provider", "method_implementation", "adapted_capability", "selectively_owned_implementation"] },
    "source": { "$ref": "#/$defs/id" },
    "sourceRevision": { "$ref": "#/$defs/id" },
    "license": { "$ref": "#/$defs/license" },
    "adoptionRung": { "enum": ["invoke", "adapt", "depend", "vendor", "fork", "port", "reimplement"] },
    "ownedBoundary": { "$ref": "#/$defs/nonemptyStrings" },
    "necessityEvidence": { "$ref": "#/$defs/evidence" },
    "compatibilityEvidence": { "$ref": "#/$defs/evidence" },
    "conformanceEvidence": { "$ref": "#/$defs/evidence" },
    "economics": { "$ref": "#/$defs/economics" },
    "assurance": { "$ref": "#/$defs/assurance" },
    "ownedModifications": { "type": "array", "items": { "$ref": "#/$defs/modification" } },
    "update": { "$ref": "#/$defs/update" },
    "rollback": { "$ref": "#/$defs/rollback" },
    "exit": { "$ref": "#/$defs/exit" },
    "retirement": { "$ref": "#/$defs/retirement" },
    "lifecycle": { "enum": ["research", "production_enabled", "rollback", "replaced", "retired", "out_of_scope"] },
    "researchAllowed": { "const": true },
    "productionEnabled": { "type": "boolean" },
    "diagnostics": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
    "provenance": {
      "type": "object", "additionalProperties": false, "required": ["recordedAt", "recordedBy"],
      "properties": { "recordedAt": { "$ref": "#/$defs/time" }, "recordedBy": { "$ref": "#/$defs/id" } }
    },
    "engineeringFacts": { "type": "array", "maxItems": 0 }
  },
  "$defs": {
    "id": { "type": "string", "minLength": 1 },
    "time": { "type": "integer", "minimum": 0 },
    "evidenceIds": { "type": "array", "uniqueItems": true, "items": { "$ref": "#/$defs/id" } },
    "nonemptyStrings": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "$ref": "#/$defs/id" } },
    "license": {
      "type": "object", "additionalProperties": false, "required": ["id", "obligations"],
      "properties": { "id": { "$ref": "#/$defs/id" }, "obligations": { "$ref": "#/$defs/nonemptyStrings" } }
    },
    "measurement": {
      "type": "object", "additionalProperties": false, "required": ["metric", "value", "unit"],
      "properties": { "metric": { "$ref": "#/$defs/id" }, "value": { "type": "number", "minimum": 0 }, "unit": { "$ref": "#/$defs/id" } }
    },
    "evidence": {
      "type": "object", "additionalProperties": false, "required": ["evidenceIds", "checkedAt", "expiresAt"],
      "properties": { "evidenceIds": { "$ref": "#/$defs/evidenceIds" }, "checkedAt": { "$ref": "#/$defs/time" }, "expiresAt": { "$ref": "#/$defs/time" } }
    },
    "economics": {
      "type": "object", "additionalProperties": false, "required": ["benefit", "cost", "benefitEvidence", "costEvidence"],
      "properties": { "benefit": { "$ref": "#/$defs/measurement" }, "cost": { "$ref": "#/$defs/measurement" }, "benefitEvidence": { "$ref": "#/$defs/evidence" }, "costEvidence": { "$ref": "#/$defs/evidence" } }
    },
    "assurance": {
      "type": "object", "additionalProperties": false, "required": ["maintenanceEvidence", "securityEvidence"],
      "properties": { "maintenanceEvidence": { "$ref": "#/$defs/evidence" }, "securityEvidence": { "$ref": "#/$defs/evidence" } }
    },
    "modification": {
      "type": "object", "additionalProperties": false, "required": ["path", "description", "evidenceIds"],
      "properties": { "path": { "$ref": "#/$defs/id" }, "description": { "$ref": "#/$defs/id" }, "evidenceIds": { "$ref": "#/$defs/evidenceIds" } }
    },
    "update": {
      "type": "object", "additionalProperties": false, "required": ["policy", "nextCheckAt", "evidence"],
      "properties": { "policy": { "$ref": "#/$defs/id" }, "nextCheckAt": { "$ref": "#/$defs/time" }, "evidence": { "$ref": "#/$defs/evidence" } }
    },
    "rollback": {
      "type": "object", "additionalProperties": false, "required": ["strategy", "evidence"],
      "properties": { "strategy": { "$ref": "#/$defs/id" }, "evidence": { "$ref": "#/$defs/evidence" } }
    },
    "exit": {
      "type": "object", "additionalProperties": false, "required": ["strategy", "replacementCriteria", "evidence"],
      "properties": { "strategy": { "$ref": "#/$defs/id" }, "replacementCriteria": { "$ref": "#/$defs/nonemptyStrings" }, "evidence": { "$ref": "#/$defs/evidence" } }
    },
    "retirement": {
      "type": "object", "additionalProperties": false, "required": ["status", "triggers", "evidence"],
      "properties": { "status": { "enum": ["active", "candidate", "approved", "completed", "out_of_scope"] }, "triggers": { "$ref": "#/$defs/nonemptyStrings" }, "evidence": { "$ref": "#/$defs/evidence" } }
    }
  }
}
