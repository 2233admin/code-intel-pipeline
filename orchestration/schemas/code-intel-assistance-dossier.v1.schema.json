{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "code-intel-assistance-dossier.v1.schema.json",
  "$defs": {
    "fit": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "basis"],
      "properties": { "status": { "enum": ["strong", "partial", "weak", "unknown"] }, "basis": { "type": "string", "minLength": 1 } }
    },
    "license": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "basis"],
      "properties": { "status": { "enum": ["acceptable", "review_required", "not_applicable", "unknown"] }, "basis": { "type": "string", "minLength": 1 } }
    },
    "security": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "basis"],
      "properties": { "status": { "enum": ["acceptable", "review_required", "unacceptable", "unknown"] }, "basis": { "type": "string", "minLength": 1 } }
    },
    "reversibility": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "basis"],
      "properties": { "status": { "enum": ["high", "medium", "low", "unknown"] }, "basis": { "type": "string", "minLength": 1 } }
    },
    "integration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["effort", "basis"],
      "properties": { "effort": { "enum": ["low", "medium", "high", "unknown"] }, "basis": { "type": "string", "minLength": 1 } }
    },
    "candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "name", "fit", "license", "security", "integration", "reversibility", "evidenceRefs"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "kind": { "enum": ["internal_atom", "established_method", "external_tool", "documentation"] },
        "name": { "type": "string", "minLength": 1 },
        "fit": { "$ref": "#/$defs/fit" },
        "license": { "$ref": "#/$defs/license" },
        "security": { "$ref": "#/$defs/security" },
        "integration": { "$ref": "#/$defs/integration" },
        "reversibility": { "$ref": "#/$defs/reversibility" },
        "evidenceRefs": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } }
      }
    }
  },
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "id", "kind", "name", "fit", "license", "security", "integration", "reversibility", "evidenceRefs", "disposition", "authorityState"],
  "properties": {
    "schema": { "const": "code-intel-assistance-dossier.v1" },
    "id": { "type": "string", "minLength": 1 },
    "kind": { "enum": ["internal_atom", "established_method", "external_tool", "documentation"] },
    "name": { "type": "string", "minLength": 1 },
    "fit": { "$ref": "#/$defs/fit" },
    "license": { "$ref": "#/$defs/license" },
    "security": { "$ref": "#/$defs/security" },
    "integration": { "$ref": "#/$defs/integration" },
    "reversibility": { "$ref": "#/$defs/reversibility" },
    "evidenceRefs": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
    "disposition": { "const": "proposal" },
    "authorityState": { "const": "unresolved" }
  }
}
