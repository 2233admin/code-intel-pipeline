{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "code-intel-artifact-index.v1.schema.json",
  "title": "Code Intel committed-run artifact index",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "entries", "diagnostics"],
  "properties": {
    "schema": { "const": "code-intel-artifact-index.v1" },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["repo", "run", "runIdentity", "snapshotIdentity", "outcome", "manifest", "artifactRefs"],
        "properties": {
          "repo": { "$ref": "#/$defs/portableName" },
          "run": { "$ref": "#/$defs/portableName" },
          "runIdentity": { "type": "string", "pattern": "^dag-v1:([a-f0-9]{2})+$" },
          "snapshotIdentity": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
          "outcome": { "const": "completed" },
          "manifest": {
            "type": "object",
            "additionalProperties": false,
            "required": ["path", "sha256"],
            "properties": {
              "path": { "type": "string", "pattern": "^objects/sha256/[a-f0-9]{64}$" },
              "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
            }
          },
          "artifactRefs": {
            "type": "array",
            "items": {
              "allOf": [
                { "$ref": "code-intel-run-manifest.v1.schema.json#/definitions/artifactRef" },
                {
                  "properties": {
                    "path": { "$ref": "#/$defs/portableRelativePath" }
                  }
                }
              ]
            }
          }
        }
      }
    },
    "diagnostics": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["repo", "run", "classification", "reason"],
        "properties": {
          "repo": { "$ref": "#/$defs/portableName" },
          "run": { "$ref": "#/$defs/portableName" },
          "classification": { "enum": ["staging", "incomplete", "forged", "legacy", "non_completed"] },
          "reason": { "type": "string", "minLength": 1 }
        }
      }
    }
  },
  "$defs": {
    "portableName": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!\\.{1,2}$)(?!.*[. ]$)[^/\\\\:*?\"<>|\\u0000-\\u001F]+$"
    },
    "portableRelativePath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?!.*\\\\)(?!.*:)(?!.*(?:^|/)\\.\\.?(?:/|$))(?!.*[. ](?:/|$))[^\\u0000-\\u001F/]+(?:/[^\\u0000-\\u001F/]+)*$"
    }
  }
}
