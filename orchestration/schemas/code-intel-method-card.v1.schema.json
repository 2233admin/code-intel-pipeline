{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "code-intel-method-card.v1",
  "title": "Code Intel Method Card and catalog documents",
  "oneOf": [
    { "$ref": "#/$defs/card" },
    { "$ref": "#/$defs/catalog" }
  ],
  "$defs": {
    "catalog": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema", "catalogVersion", "selectionPolicy", "cards"],
      "properties": {
        "schema": { "const": "code-intel-method-catalog.v1" },
        "catalogVersion": { "type": "string", "minLength": 1 },
        "selectionPolicy": { "const": "none_catalog_only" },
        "cards": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "path"],
            "properties": {
              "id": { "$ref": "#/$defs/id" },
              "path": { "type": "string", "pattern": "^cards/[a-z0-9-]+\\.v1\\.json$" }
            }
          }
        }
      }
    },
    "card": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema", "id", "version", "name", "problemSignals", "requiredEvidence",
        "assumptions", "deterministicSteps", "outputs", "confidenceRules", "cost",
        "contraindications", "implementationPorts", "source", "applicabilityBoundary",
        "relatedMethodIds", "executionPolicy"
      ],
      "properties": {
        "schema": { "const": "code-intel-method-card.v1" },
        "id": { "$ref": "#/$defs/id" },
        "version": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "problemSignals": { "$ref": "#/$defs/describedIds" },
        "requiredEvidence": { "$ref": "#/$defs/describedIds" },
        "assumptions": { "$ref": "#/$defs/nonemptyStrings" },
        "deterministicSteps": {
          "type": "array", "minItems": 1,
          "items": {
            "type": "object", "additionalProperties": false,
            "required": ["id", "action", "requires", "produces"],
            "properties": {
              "id": { "$ref": "#/$defs/id" },
              "action": { "type": "string", "minLength": 1 },
              "requires": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
              "produces": { "$ref": "#/$defs/nonemptyStrings" }
            }
          }
        },
        "outputs": { "$ref": "#/$defs/describedIds" },
        "confidenceRules": {
          "type": "array", "minItems": 1,
          "items": {
            "type": "object", "additionalProperties": false,
            "required": ["level", "whenAll"],
            "properties": {
              "level": { "enum": ["unknown", "low", "medium", "high"] },
              "whenAll": { "$ref": "#/$defs/nonemptyStrings" }
            }
          }
        },
        "cost": { "$ref": "#/$defs/cost" },
        "contraindications": { "$ref": "#/$defs/nonemptyStrings" },
        "implementationPorts": {
          "type": "array", "minItems": 1,
          "items": {
            "type": "object", "additionalProperties": false,
            "required": ["id", "kind", "contract"],
            "properties": {
              "id": { "$ref": "#/$defs/id" },
              "kind": { "enum": ["manual", "deterministic_tool", "statistical_engine", "modeling_tool"] },
              "contract": { "$ref": "#/$defs/nonemptyStrings" }
            }
          }
        },
        "source": {
          "type": "object", "additionalProperties": false,
          "required": ["title", "version", "reference"],
          "properties": {
            "title": { "type": "string", "minLength": 1 },
            "version": { "type": "string", "minLength": 1 },
            "reference": { "type": "string", "minLength": 1 }
          }
        },
        "applicabilityBoundary": {
          "type": "object", "additionalProperties": false,
          "required": ["inScope", "outOfScope"],
          "properties": {
            "inScope": { "$ref": "#/$defs/nonemptyStrings" },
            "outOfScope": { "$ref": "#/$defs/nonemptyStrings" }
          }
        },
        "relatedMethodIds": { "type": "array", "items": { "$ref": "#/$defs/id" }, "uniqueItems": true },
        "executionPolicy": { "const": "catalog_only_no_selection_or_execution" }
      }
    },
    "cost": {
      "type": "object", "additionalProperties": false,
      "required": ["relative", "drivers"],
      "properties": {
        "relative": { "enum": ["low", "medium", "high"] },
        "drivers": { "$ref": "#/$defs/nonemptyStrings" }
      }
    },
    "describedIds": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["id", "description"],
        "properties": {
          "id": { "$ref": "#/$defs/id" },
          "description": { "type": "string", "minLength": 1 }
        }
      }
    },
    "nonemptyStrings": {
      "type": "array", "minItems": 1, "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "id": { "type": "string", "pattern": "^[a-z0-9-]{1,96}$" }
  }
}
