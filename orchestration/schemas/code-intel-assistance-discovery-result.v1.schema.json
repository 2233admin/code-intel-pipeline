{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "code-intel-assistance-discovery-result.v1.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "status", "gapId", "capability", "gapEvidenceRefs", "dossiers", "proposalOnly", "selectionPolicy", "effects", "authorityEvents", "adoptionDecisions", "committedEngineeringPlans"],
  "properties": {
    "schema": { "const": "code-intel-assistance-discovery-result.v1" },
    "status": { "const": "completed" },
    "gapId": { "type": "string", "minLength": 1 },
    "capability": { "type": "string", "minLength": 1 },
    "gapEvidenceRefs": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
    "dossiers": { "type": "array", "minItems": 1, "uniqueItems": true, "x-code-intel-uniqueBy": "id", "items": { "$ref": "code-intel-assistance-dossier.v1.schema.json" } },
    "proposalOnly": { "const": true },
    "selectionPolicy": { "const": "evidence_and_constraints_not_popularity" },
    "effects": { "type": "array", "maxItems": 0 },
    "authorityEvents": { "type": "array", "maxItems": 0 },
    "adoptionDecisions": { "type": "array", "maxItems": 0 },
    "committedEngineeringPlans": { "type": "array", "maxItems": 0 }
  }
}
