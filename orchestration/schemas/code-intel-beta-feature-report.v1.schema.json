{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://code-intel.local/schemas/code-intel-beta-feature-report.v1.schema.json",
  "title": "Code Intel Experimental Beta Feature Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "feature",
    "beta",
    "snapshotIdentity",
    "status",
    "summary",
    "issues",
    "recommendations",
    "coverage",
    "source"
  ],
  "properties": {
    "schema": { "const": "code-intel-beta-feature-report.v1" },
    "feature": {
      "enum": ["competitive-intelligence", "react-diagnostics"]
    },
    "beta": { "const": true },
    "snapshotIdentity": {
      "type": ["string", "null"],
      "pattern": "^[0-9a-f]{64}$"
    },
    "status": {
      "enum": ["observed", "unknown", "not_applicable", "rejected"]
    },
    "summary": { "type": ["string", "null"] },
    "issues": {
      "type": "array",
      "items": { "$ref": "#/$defs/issue" }
    },
    "recommendations": {
      "type": "array",
      "items": { "$ref": "#/$defs/recommendation" }
    },
    "coverage": {
      "type": ["array", "null"]
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "provider",
        "advisoryOnly",
        "admissibility",
        "failureCategory",
        "evaluatedAt"
      ],
      "properties": {
        "provider": { "enum": ["compete", "react-doctor"] },
        "advisoryOnly": { "const": true },
        "admissibility": { "type": ["object", "null"] },
        "failureCategory": { "type": ["string", "null"] },
        "evaluatedAt": { "type": ["integer", "null"], "minimum": 0 }
      }
    }
  },
  "$defs": {
    "issue": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "kind",
        "title",
        "description",
        "severity",
        "category",
        "location",
        "sourceEvidence"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "kind": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": ["string", "null"] },
        "severity": { "type": "string", "minLength": 1 },
        "category": { "type": "string", "minLength": 1 },
        "location": { "type": ["object", "null"] },
        "sourceEvidence": {}
      }
    },
    "recommendation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "rationale",
        "priority",
        "sourceIssueIds",
        "confidence"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "rationale": { "type": ["string", "null"] },
        "priority": { "type": "string", "minLength": 1 },
        "sourceIssueIds": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "confidence": {}
      }
    }
  }
}
