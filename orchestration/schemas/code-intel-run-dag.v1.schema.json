{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://code-intel.local/schemas/code-intel-run-dag.v1.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "snapshotIdentity", "maxConcurrency", "nodes", "edges"],
  "properties": {
    "schema": { "const": "code-intel-run-dag.v1" },
    "snapshotIdentity": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "maxConcurrency": { "type": "integer", "minimum": 1, "maximum": 256 },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "capability", "requestIdentity"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]*$" },
          "capability": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]*$" },
          "requestIdentity": { "type": "string", "minLength": 1 }
        }
      }
    },
    "edges": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["from", "to"],
        "properties": {
          "from": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]*$" },
          "to": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]*$" }
        }
      }
    }
  }
}
