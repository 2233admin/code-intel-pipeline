{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "code-intel-delivery-light-speed.v1.schema.json",
  "title": "Delivery Light-Speed Measurement",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "measurementSnapshotIdentity", "authority", "method", "rules", "baseline", "current", "delta", "limitations"],
  "properties": {
    "schema": { "const": "code-intel-delivery-light-speed.v1" },
    "measurementSnapshotIdentity": { "$ref": "#/$defs/digest" },
    "authority": { "const": "derived_measurement_no_schedule_commitment" },
    "method": {
      "type": "object",
      "additionalProperties": false,
      "required": ["methodCardIds", "provenance", "valueStreamFormula", "queueFormula", "criticalPathFormula", "deltaFormula"],
      "properties": {
        "methodCardIds": { "$ref": "#/$defs/methodCards" },
        "provenance": {
          "type": "object",
          "additionalProperties": false,
          "required": ["catalogRef", "catalogSha256", "methodCardRefs", "methodCardSha256"],
          "properties": {
            "catalogRef": { "$ref": "#/$defs/artifactRef" },
            "catalogSha256": { "$ref": "#/$defs/digest" },
            "methodCardRefs": { "type": "array", "minItems": 2, "maxItems": 2, "items": { "$ref": "#/$defs/artifactRef" } },
            "methodCardSha256": { "type": "array", "minItems": 2, "maxItems": 2, "items": { "$ref": "#/$defs/digest" } }
          }
        },
        "valueStreamFormula": { "type": "string", "minLength": 1 },
        "queueFormula": { "type": "string", "minLength": 1 },
        "criticalPathFormula": { "type": "string", "minLength": 1 },
        "deltaFormula": { "type": "string", "minLength": 1 }
      }
    },
    "rules": { "type": "array", "minItems": 7, "items": { "$ref": "#/$defs/rule" } },
    "baseline": { "$ref": "#/$defs/measurement" },
    "current": { "$ref": "#/$defs/measurement" },
    "delta": { "$ref": "#/$defs/delta" },
    "limitations": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } }
  },
  "$defs": {
    "digest": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "artifactRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema", "artifactSchema", "type", "path", "sha256", "consumedSnapshotIdentity"],
      "properties": {
        "schema": { "const": "code-intel-artifact-ref.v1" },
        "artifactSchema": { "type": "string", "minLength": 1 },
        "type": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 },
        "sha256": { "$ref": "#/$defs/digest" },
        "consumedSnapshotIdentity": { "$ref": "#/$defs/digest" }
      }
    },
    "methodCards": {
      "const": ["critical-path-pert", "value-stream-queue-delay"]
    },
    "rule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "methodCardIds", "rule"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "methodCardIds": { "$ref": "#/$defs/methodCards" },
        "rule": { "type": "string", "minLength": 1 }
      }
    },
    "commit": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema", "runIdentity", "snapshotIdentity", "manifest"],
      "properties": {
        "schema": { "const": "code-intel-run-commit.v1" },
        "runIdentity": { "type": "string", "pattern": "^dag-v1:[0-9a-f]+$" },
        "snapshotIdentity": { "$ref": "#/$defs/digest" },
        "manifest": {
          "type": "object",
          "additionalProperties": false,
          "required": ["path", "sha256"],
          "properties": {
            "path": { "type": "string", "pattern": "^objects/sha256/[0-9a-f]{64}$" },
            "sha256": { "$ref": "#/$defs/digest" }
          }
        }
      }
    },
    "categories": {
      "type": "object",
      "additionalProperties": false,
      "required": ["irreducibleTechnicalWorkMs", "mandatoryVerificationMs", "requiredCoordinationMs", "queueMs", "handoffMs", "repeatedUnderstandingMs", "reworkMs", "unnecessaryCoordinationMs"],
      "properties": {
        "irreducibleTechnicalWorkMs": { "type": "integer", "minimum": 0 },
        "mandatoryVerificationMs": { "type": "integer", "minimum": 0 },
        "requiredCoordinationMs": { "type": "integer", "minimum": 0 },
        "queueMs": { "type": "integer", "minimum": 0 },
        "handoffMs": { "type": "integer", "minimum": 0 },
        "repeatedUnderstandingMs": { "type": "integer", "minimum": 0 },
        "reworkMs": { "type": "integer", "minimum": 0 },
        "unnecessaryCoordinationMs": { "type": "integer", "minimum": 0 }
      }
    },
    "criticalPath": {
      "type": "object",
      "additionalProperties": false,
      "required": ["eventIds", "durationMs", "irreducibleTechnicalWorkMs", "mandatoryVerificationMs", "requiredCoordinationMs", "queueMs", "handoffMs", "repeatedUnderstandingMs", "reworkMs", "unnecessaryCoordinationMs", "avoidableDelayMs"],
      "properties": {
        "eventIds": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "durationMs": { "type": "integer", "minimum": 1 },
        "irreducibleTechnicalWorkMs": { "type": "integer", "minimum": 0 },
        "mandatoryVerificationMs": { "type": "integer", "minimum": 0 },
        "requiredCoordinationMs": { "type": "integer", "minimum": 0 },
        "queueMs": { "type": "integer", "minimum": 0 },
        "handoffMs": { "type": "integer", "minimum": 0 },
        "repeatedUnderstandingMs": { "type": "integer", "minimum": 0 },
        "reworkMs": { "type": "integer", "minimum": 0 },
        "unnecessaryCoordinationMs": { "type": "integer", "minimum": 0 },
        "avoidableDelayMs": { "type": "integer", "minimum": 0 }
      }
    },
    "provenanceItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sourceArtifactSha256", "jsonPointers", "eventIds", "ruleId"],
      "properties": {
        "sourceArtifactSha256": { "$ref": "#/$defs/digest" },
        "jsonPointers": { "type": "array", "items": { "type": "string", "pattern": "^/" } },
        "eventIds": { "type": "array", "items": { "type": "string" } },
        "ruleId": { "type": "string", "minLength": 1 }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["irreducibleTechnicalWorkMs", "mandatoryVerificationMs", "requiredCoordinationMs", "queueMs", "handoffMs", "repeatedUnderstandingMs", "reworkMs", "unnecessaryCoordinationMs"],
      "properties": {
        "irreducibleTechnicalWorkMs": { "$ref": "#/$defs/provenanceItem" },
        "mandatoryVerificationMs": { "$ref": "#/$defs/provenanceItem" },
        "requiredCoordinationMs": { "$ref": "#/$defs/provenanceItem" },
        "queueMs": { "$ref": "#/$defs/provenanceItem" },
        "handoffMs": { "$ref": "#/$defs/provenanceItem" },
        "repeatedUnderstandingMs": { "$ref": "#/$defs/provenanceItem" },
        "reworkMs": { "$ref": "#/$defs/provenanceItem" },
        "unnecessaryCoordinationMs": { "$ref": "#/$defs/provenanceItem" }
      }
    },
    "measurement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["commitRef", "commit", "leadTimeMs", "touchTimeMs", "categories", "avoidableDelayMs", "criticalPath", "provenance"],
      "properties": {
        "commitRef": { "$ref": "#/$defs/artifactRef" },
        "commit": { "$ref": "#/$defs/commit" },
        "leadTimeMs": { "type": "integer", "minimum": 1 },
        "touchTimeMs": { "type": "integer", "minimum": 1 },
        "categories": { "$ref": "#/$defs/categories" },
        "avoidableDelayMs": { "type": "integer", "minimum": 0 },
        "criticalPath": { "$ref": "#/$defs/criticalPath" },
        "provenance": { "$ref": "#/$defs/provenance" }
      }
    },
    "delta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["formula", "leadTimeMs", "touchTimeMs", "irreducibleTechnicalWorkMs", "mandatoryVerificationMs", "requiredCoordinationMs", "queueMs", "handoffMs", "repeatedUnderstandingMs", "reworkMs", "unnecessaryCoordinationMs", "avoidableDelayMs"],
      "properties": {
        "formula": { "const": "current_minus_baseline_ms" },
        "leadTimeMs": { "type": "integer" },
        "touchTimeMs": { "type": "integer" },
        "irreducibleTechnicalWorkMs": { "type": "integer" },
        "mandatoryVerificationMs": { "type": "integer" },
        "requiredCoordinationMs": { "type": "integer" },
        "queueMs": { "type": "integer" },
        "handoffMs": { "type": "integer" },
        "repeatedUnderstandingMs": { "type": "integer" },
        "reworkMs": { "type": "integer" },
        "unnecessaryCoordinationMs": { "type": "integer" },
        "avoidableDelayMs": { "type": "integer" }
      }
    }
  }
}
