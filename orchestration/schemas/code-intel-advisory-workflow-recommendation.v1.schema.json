{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "code-intel-advisory-workflow-recommendation.v1.schema.json",
  "title": "Code Intel advisory workflow recommendation",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "kind", "recommendation", "evidence", "confidence", "alternatives", "provenance", "effects"],
  "properties": {
    "schema": { "const": "code-intel-advisory-workflow-recommendation.v1" },
    "kind": { "const": "proposal" },
    "recommendation": { "$ref": "#/$defs/candidate" },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind", "value"],
        "properties": {
          "kind": { "type": "string", "minLength": 1 },
          "value": { "type": "string", "minLength": 1 }
        }
      }
    },
    "confidence": { "enum": ["low", "medium", "high"] },
    "alternatives": {
      "type": "array",
      "minItems": 3,
      "items": { "$ref": "#/$defs/candidate" }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["capabilityId", "implementation", "repository", "compatibilityOptions"],
      "properties": {
        "capabilityId": { "const": "advisory.workflow-recommend" },
        "implementation": { "const": "OpenSpec-Detector.ps1" },
        "repository": { "type": "string", "minLength": 1 },
        "compatibilityOptions": {
          "type": "object",
          "additionalProperties": false,
          "required": ["auto"],
          "properties": { "auto": { "type": "boolean" } }
        }
      }
    },
    "effects": { "type": "array", "maxItems": 0 }
  },
  "$defs": {
    "candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["candidate", "stack", "verdict", "score", "reasons", "entrySkills"],
      "properties": {
        "candidate": { "type": "string", "minLength": 1 },
        "stack": { "enum": ["matt-flow", "gstack", "spec-driven"] },
        "verdict": { "type": "string", "minLength": 1 },
        "score": { "type": "integer", "minimum": 0, "maximum": 100 },
        "reasons": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "entrySkills": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "brief": { "type": "object" }
      }
    }
  }
}
