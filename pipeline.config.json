{
  "artifactRoot": "",
  "repowiseWorkspaceRoot": "",
  "codeEvidence": {
    "enabled": true,
    "nativeMinimal": true,
    "adapters": {
      "cocoindex-code": {
        "enabled": false,
        "mode": "evaluate",
        "required": false,
        "offlineOnly": true
      }
    }
  },
  "inventoryExclude": [
    "!**/tools/**",
    "!**/vendor/**",
    "!**/third_party/**",
    "!**/external/**",
    "!**/.tmp-*/**",
    "!**/opencli_admin.db",
    "!**/*.png"
  ],
  "repos": {
    "opencli-admin": {
      "path": "D:\\projects\\opencli-admin",
      "sentruxPath": ""
    },
    "opencli-admin-backend": {
      "path": "D:\\projects\\opencli-admin",
      "sentruxPath": "backend"
    },
    "opencli-admin-frontend": {
      "path": "D:\\projects\\opencli-admin",
      "sentruxPath": "frontend"
    },
    "opencli-admin-agent": {
      "path": "D:\\projects\\opencli-admin",
      "sentruxPath": "agent"
    },
    "opencli-admin-chrome": {
      "path": "D:\\projects\\opencli-admin",
      "sentruxPath": "chrome"
    },
    "opencli-admin-odp": {
      "path": "D:\\projects\\opencli-admin",
      "sentruxPath": "odp-rs"
    },
    "opencli-admin-iii": {
      "path": "D:\\projects\\opencli-admin",
      "sentruxPath": "iii"
    },
    "projects": {
      "path": "D:\\projects"
    }
  }
}
