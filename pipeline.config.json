{
  "artifactRoot": "",
  "repowiseWorkspaceRoot": "",
  "codeEvidence": {
    "enabled": true,
    "nativeMinimal": true,
    "adapters": {
      "cocoindex-code": {
        "enabled": false,
        "mode": "evaluate",
        "required": false,
        "offlineOnly": true
      }
    }
  },
  "inventoryExclude": [
    "!**/tools/**",
    "!**/vendor/**",
    "!**/third_party/**",
    "!**/external/**",
    "!**/.tmp-*/**",
    "!**/opencli_admin.db",
    "!**/*.png"
  ],
  "repos": {
    "projects": {
      "path": "D:\\projects",
      "language": "zh"
    },
    "workbench-kernel": {
      "path": "D:\\projects\\workbench-kernel",
      "repowiseScopePaths": [
        "apps/lab/src",
        "apps/geoflow/src",
        "apps/red-queen/src",
        "packages/components/src",
        "packages/data-grid-contract/src",
        "packages/evidence/src",
        "packages/primitives/src",
        "packages/stream-contract/src",
        "packages/terminal/src",
        "packages/tokens/src",
        "packages/tv-chart/src",
        "packages/workspace/src",
        "docs"
      ],
      "repowiseRootFiles": [
        "README.md",
        "CLAUDE.md",
        "package.json",
        "pnpm-workspace.yaml",
        ".gitignore"
      ]
    },
    "k-atana": {
      "path": "D:\\projects\\k-atana",
      "language": "zh",
      "sentruxPath": "backend",
      "repowiseScopePaths": ["backend"],
      "repowiseRootFiles": ["README.md", "CLAUDE.md", "pyproject.toml", "requirements.txt", ".env.example", ".gitignore"]
    },
    "aigx": {
      "path": "D:\\projects\\AIGX",
      "language": "zh",
      "sentruxPath": "tools",
      "repowiseScopePaths": ["crates", "packages", "tools", "bin", "scripts", "standard", "docs", "integrations", "editors", "examples", "templates", "tests"],
      "repowiseRootFiles": ["README.md", "SPEC.md", "package.json", "pyproject.toml", "llms.txt", ".gitignore"]
    },
    "opencli-admin": {
      "path": "D:\\projects\\opencli-admin",
      "sentruxPath": ""
    },
    "opencli-admin-backend": {
      "path": "D:\\projects\\opencli-admin",
      "sentruxPath": "backend"
    },
    "opencli-admin-frontend": {
      "path": "D:\\projects\\opencli-admin",
      "sentruxPath": "frontend"
    },
    "opencli-admin-agent": {
      "path": "D:\\projects\\opencli-admin",
      "sentruxPath": "agent"
    },
    "opencli-admin-chrome": {
      "path": "D:\\projects\\opencli-admin",
      "sentruxPath": "chrome"
    },
    "opencli-admin-odp": {
      "path": "D:\\projects\\opencli-admin",
      "sentruxPath": "odp-rs"
    },
    "opencli-admin-iii": {
      "path": "D:\\projects\\opencli-admin",
      "sentruxPath": "iii"
    }
  }
}
