{
  "artifactRoot": "",
  "repowiseWorkspaceRoot": "",
  "codeEvidence": {
    "enabled": true,
    "nativeMinimal": true,
    "adapters": {
      "cocoindex-code": {
        "enabled": false,
        "mode": "evaluate",
        "required": false,
        "offlineOnly": true
      }
    }
  },
  "repomix": {
    "enabled": true,
    "style": "markdown",
    "compress": false
  },
  "followUpAutomation": {
    "proactiveSkillSuggestions": {
      "enabled": true,
      "bugSkill": "/investigate"
    },
    "automaticPullRequests": {
      "mode": "ask"
    }
  },
  "inventoryExclude": [
    "!**/tools/**",
    "!**/vendor/**",
    "!**/third_party/**",
    "!**/external/**"
  ],
  "repos": {
    "example-repo": {
      "path": "C:\\path\\to\\repo",
      "language": "zh",
      "sentruxPath": "",
      "repowiseScopePaths": [],
      "repowiseRootFiles": []
    }
  }
}
